#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_DIR="$ROOT_DIR/.venv"
INSTALL_STAMP="$VENV_DIR/.weather-cmd-installed"

print_fix_hint() {
    cat >&2 <<'EOF'
What to do:
  1. Make sure Python 3.12+ is installed and available as `python3`.
  2. Make sure this machine has internet access for package installation.
  3. From the repo root, run:
     python3 -m venv .venv
     .venv/bin/pip install -e .
  4. Retry:
     ./weather-cmd --help
EOF
}

fail() {
    echo "weather-cmd launcher error: $1" >&2
    print_fix_hint
    exit 1
}

if ! command -v python3 >/dev/null 2>&1; then
    fail "python3 was not found in PATH."
fi

if [[ ! -x "$VENV_DIR/bin/python" ]]; then
    echo "Creating virtual environment in $VENV_DIR" >&2
    if ! python3 -m venv "$VENV_DIR"; then
        fail "failed to create virtual environment in $VENV_DIR."
    fi
fi

NEEDS_INSTALL=0

if [[ ! -x "$VENV_DIR/bin/weather-cmd" ]]; then
    NEEDS_INSTALL=1
elif [[ ! -f "$INSTALL_STAMP" ]]; then
    touch "$INSTALL_STAMP"
elif [[ "$ROOT_DIR/pyproject.toml" -nt "$INSTALL_STAMP" ]]; then
    NEEDS_INSTALL=1
fi

if [[ "$NEEDS_INSTALL" -eq 1 ]]; then
    INSTALL_LOG="$(mktemp)"
    echo "Installing weather-cmd dependencies into $VENV_DIR" >&2
    if ! "$VENV_DIR/bin/pip" install -e "$ROOT_DIR" >"$INSTALL_LOG" 2>&1; then
        cat "$INSTALL_LOG" >&2
        rm -f "$INSTALL_LOG"
        fail "dependency installation failed."
    fi
    rm -f "$INSTALL_LOG"
    touch "$INSTALL_STAMP"
fi

if [[ ! -x "$VENV_DIR/bin/weather-cmd" ]]; then
    fail "installation completed but $VENV_DIR/bin/weather-cmd was not created."
fi

exec "$VENV_DIR/bin/weather-cmd" "$@"
